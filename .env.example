# Example env vars for analytics
# Client-visible ID for gtag (public)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Server-side secret for GA Measurement Protocol (keep private)
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA_API_SECRET=your_ga_api_secret_here

# Optional: other service config
# MONGODB_URI=
# EMAIL_PROVIDER_API_KEY=
